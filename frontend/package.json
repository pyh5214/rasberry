{
  "name": "poem-generator",
  "version": "1.0.0",
  "description": "이미지를 분석하여 시를 생성하는 웹 애플리케이션",
  "main": "public/electron.js",
  "homepage": "./",
  "scripts": {
    "start": "react-scripts --openssl-legacy-provider start",
    "build": "react-scripts build",
    "test": "react-scripts test",
